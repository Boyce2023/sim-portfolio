{
  "_meta": {
    "schema_version": "1.0",
    "purpose": "Decision Audit Trail — 每笔交易的完整推理链。每个决策可追溯、可审计。",
    "created": "2026-05-21",
    "file_naming": "YYYY-MM-DD-TICKER-ACTION.json | 同日同ticker多笔: YYYY-MM-DD-TICKER-ACTION-NNN.json",
    "path_convention": "sim-portfolio/audit-trail/",
    "fields_required": ["trade_id", "timestamp", "ticker", "action", "shares", "price", "decision_chain", "post_trade_state"],
    "fields_optional": ["account", "currency", "value"]
  },
  "schema": {
    "trade_id": {
      "type": "string",
      "description": "唯一交易ID，从portfolio_state.json trade_log中的id字段读取",
      "example": "TRD-D1-001",
      "required": true
    },
    "timestamp": {
      "type": "string",
      "format": "ISO 8601",
      "description": "交易执行时间戳",
      "example": "2026-05-18T13:30:00+08:00",
      "required": true
    },
    "ticker": {
      "type": "string",
      "description": "交易标的代码",
      "example": "NVDA",
      "required": true
    },
    "action": {
      "type": "string",
      "enum": ["buy", "sell", "short", "cover"],
      "description": "交易方向",
      "required": true
    },
    "account": {
      "type": "string",
      "enum": ["us", "a_share"],
      "description": "交易账户",
      "required": true
    },
    "shares": {
      "type": "number",
      "description": "交易股数",
      "required": true
    },
    "price": {
      "type": "number",
      "description": "成交价格（账户对应货币）",
      "required": true
    },
    "currency": {
      "type": "string",
      "enum": ["USD", "CNY"],
      "required": true
    },
    "value": {
      "type": "number",
      "description": "交易总金额 = shares × price",
      "required": true
    },
    "decision_chain": {
      "type": "object",
      "description": "完整决策链条，记录从触发到执行的全过程",
      "required": true,
      "properties": {
        "trigger": {
          "type": "object",
          "required": true,
          "properties": {
            "type": {
              "type": "string",
              "enum": ["catalyst", "stop_loss", "research", "momentum", "rebalance", "new_ipo", "portfolio_init"],
              "description": "触发类型"
            },
            "description": {
              "type": "string",
              "description": "触发交易的具体信号描述"
            },
            "source": {
              "type": "string",
              "enum": ["decision_engine", "manual", "risk_monitor", "auto_stoploss"],
              "description": "信号来源"
            }
          }
        },
        "thesis_check": {
          "type": "object",
          "required": true,
          "properties": {
            "thesis": {
              "type": "string",
              "description": "核心投资逻辑（一句话）"
            },
            "thesis_still_valid": {
              "type": "boolean",
              "description": "建仓/加仓时thesis是否成立；卖出时记录失效原因"
            },
            "bear_case": {
              "type": "string",
              "description": "主要风险点描述"
            },
            "bear_case_downside_pct": {
              "type": "number",
              "description": "熊市情景最大回撤%（负数）。硬规则: < -20% 不建仓",
              "maximum": 0
            },
            "bear_case_rule_pass": {
              "type": "boolean",
              "description": "bear case是否通过 <= -20%规则"
            },
            "abcd_classification": {
              "type": "string",
              "enum": ["A", "B", "C", "D", "N/A"],
              "description": "卖出时的ABCD下跌分类；买入时填N/A"
            }
          }
        },
        "risk_check": {
          "type": "object",
          "required": true,
          "properties": {
            "pre_trade_cash_pct": {
              "type": "number",
              "description": "交易前现金比例%"
            },
            "post_trade_cash_pct": {
              "type": "number",
              "description": "交易后现金比例%"
            },
            "position_size_pct": {
              "type": "number",
              "description": "该仓位占总NAV%"
            },
            "single_position_limit_ok": {
              "type": "boolean",
              "description": "单只<=15%规则是否通过"
            },
            "sector_limit_ok": {
              "type": "boolean",
              "description": "单板块<=30%规则是否通过"
            },
            "cash_minimum_ok": {
              "type": "boolean",
              "description": "现金>=20%规则是否通过"
            },
            "circuit_breaker_status": {
              "type": "string",
              "enum": ["clear", "warning", "triggered"],
              "description": "风控熔断状态"
            }
          }
        },
        "sizing": {
          "type": "object",
          "required": true,
          "properties": {
            "method": {
              "type": "string",
              "enum": ["fixed_pct", "kelly", "manual", "stop_loss_auto"],
              "description": "仓位计算方法"
            },
            "target_pct": {
              "type": "number",
              "description": "目标仓位%"
            },
            "kelly_recommended_pct": {
              "type": ["number", "null"],
              "description": "Kelly公式推荐仓位%（未使用时填null）"
            },
            "confidence_level": {
              "type": "string",
              "enum": ["A", "B", "C"],
              "description": "信心等级: A=高(全仓押注), B=中(试探建仓), C=低(最小仓观察)"
            },
            "reason": {
              "type": "string",
              "description": "仓位大小的决策理由"
            }
          }
        },
        "final_decision": {
          "type": "object",
          "required": true,
          "properties": {
            "approved": {
              "type": "boolean",
              "description": "交易是否批准执行"
            },
            "approver": {
              "type": "string",
              "enum": ["auto", "manual"],
              "description": "批准方式：auto=系统自动/止损触发，manual=人工决策"
            },
            "overrides": {
              "type": "array",
              "items": {"type": "string"},
              "description": "覆盖了哪些规则（列举），正常情况为空数组"
            },
            "notes": {
              "type": "string",
              "description": "额外备注（用户确认内容、特殊情况说明等）"
            }
          }
        }
      }
    },
    "post_trade_state": {
      "type": "object",
      "description": "交易后组合状态快照",
      "required": true,
      "properties": {
        "account_cash_pct": {
          "type": "number",
          "description": "账户现金比例%"
        },
        "account_total_positions": {
          "type": "number",
          "description": "账户持仓数量"
        },
        "account_nav": {
          "type": "number",
          "description": "账户总资产（本位币）"
        },
        "realized_pnl": {
          "type": ["number", "null"],
          "description": "本笔交易实现的P&L（仅卖出时有值）"
        }
      }
    }
  },
  "enums_reference": {
    "trigger_types": {
      "portfolio_init": "组合首次建仓（Day1批量建立底仓）",
      "catalyst": "事件催化剂触发（财报/发布会/政策）",
      "stop_loss": "止损触发（价格跌破止损线）",
      "research": "研究驱动（新发现/重新评估thesis）",
      "momentum": "动量跟随（财报前建仓/技术面信号）",
      "rebalance": "再平衡（仓位调整）",
      "new_ipo": "新股IPO建仓"
    },
    "confidence_levels": {
      "A": "高信心，充分研究+催化剂明确+bear case通过，目标仓位10-15%",
      "B": "中信心，thesis初步验证，试探建仓5-8%，等后续催化剂加仓",
      "C": "低信心，观察仓，最小规模<5%，主要目的是持续跟踪"
    },
    "abcd_classification": {
      "A": "大盘系统性拖累 → Hold，不恐慌卖出",
      "B": "板块轮动 → Hold，监控轮动信号",
      "C": "公司叙事变化 → 减30-50%，重新评估thesis",
      "D": "Thesis被证伪 → 立即清仓，不犹豫"
    }
  },
  "example": {
    "trade_id": "TRD-D1-001",
    "timestamp": "2026-05-18T13:30:00+08:00",
    "ticker": "NVDA",
    "action": "buy",
    "account": "us",
    "shares": 80,
    "price": 225.0,
    "currency": "USD",
    "value": 18000,
    "decision_chain": {
      "trigger": {
        "type": "portfolio_init",
        "description": "Day1组合建立，AI基础设施底仓首建",
        "source": "manual"
      },
      "thesis_check": {
        "thesis": "CUDA护城河400M+开发者，B200/GB200超级周期，AI基础设施不可替代",
        "thesis_still_valid": true,
        "bear_case": "DeepSeek类效率突破使硬件需求萎缩 + 中国出口管制再升级",
        "bear_case_downside_pct": -18,
        "bear_case_rule_pass": true,
        "abcd_classification": "N/A"
      },
      "risk_check": {
        "pre_trade_cash_pct": 100.0,
        "post_trade_cash_pct": 88.0,
        "position_size_pct": 12.0,
        "single_position_limit_ok": true,
        "sector_limit_ok": true,
        "cash_minimum_ok": true,
        "circuit_breaker_status": "clear"
      },
      "sizing": {
        "method": "fixed_pct",
        "target_pct": 12.0,
        "kelly_recommended_pct": null,
        "confidence_level": "A",
        "reason": "AI基础设施核心标的，共识满但底仓必须持有，12%接近单仓上限"
      },
      "final_decision": {
        "approved": true,
        "approver": "manual",
        "overrides": [],
        "notes": "15/15卖方看多=共识满=alpha低，但作为AI基础设施不可或缺的底仓必须持有"
      }
    },
    "post_trade_state": {
      "account_cash_pct": 38.6,
      "account_total_positions": 8,
      "account_nav": 150000,
      "realized_pnl": null
    }
  }
}
